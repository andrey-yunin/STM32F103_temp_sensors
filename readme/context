    29 void CAN_SendAck(uint16_t cmd_code) {
    30     CanTxFrame_t tx;
    31     tx.header.ExtId = CAN_BUILD_ID(CAN_PRIORITY_NORMAL, CAN_MSG_TYPE_ACK, CAN_ADDR_CONDUCTOR, CAN_ADDR_THERMO_BOARD);
    32     tx.header.IDE = CAN_ID_EXT;
    33     tx.header.RTR = CAN_RTR_DATA;
    34     tx.header.DLC = 2;
    35     tx.data[0] = (uint8_t)(cmd_code & 0xFF);
    36     tx.data[1] = (uint8_t)((cmd_code >> 8) & 0xFF);
    37
    38     osMessageQueuePut(can_tx_queueHandle, &tx, 0, 0);
    39     osThreadFlagsSet(task_can_handleHandle, FLAG_CAN_TX);
    40 }
    41
    42 void CAN_SendNack(uint16_t cmd_code, uint16_t error_code) {
    43     CanTxFrame_t tx;
    44     tx.header.ExtId = CAN_BUILD_ID(CAN_PRIORITY_NORMAL, CAN_MSG_TYPE_NACK, CAN_ADDR_CONDUCTOR, CAN_ADDR_THERMO_BOARD);
    45     tx.header.IDE = CAN_ID_EXT;
    46     tx.header.RTR = CAN_RTR_DATA;
    47     tx.header.DLC = 4;
    48     tx.data[0] = (uint8_t)(cmd_code & 0xFF);
    49     tx.data[1] = (uint8_t)((cmd_code >> 8) & 0xFF);
    50     tx.data[2] = (uint8_t)(error_code & 0xFF);
    51     tx.data[3] = (uint8_t)((error_code >> 8) & 0xFF);
    52
    53     osMessageQueuePut(can_tx_queueHandle, &tx, 0, 0);
    54     osThreadFlagsSet(task_can_handleHandle, FLAG_CAN_TX);
    55 }

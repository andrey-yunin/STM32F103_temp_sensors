    5 // Глобальная переменная конфигурации в оперативной памяти
    6 AppConfig_t g_app_config;
    7
    8 /**
    9  * @brief Простая контрольная сумма (Checksum) для структуры.
   10  */
   11 static uint16_t CalculateChecksum(AppConfig_t* cfg) {
   12     uint16_t checksum = 0;
   13     uint8_t* p = (uint8_t*)cfg;
   14     // Считаем все поля, кроме поля checksum (оно последнее)
   15     for (uint32_t i = 0; i < sizeof(AppConfig_t) - sizeof(uint16_t); i++) {
   16         checksum += p[i];
   17     }
   18     return checksum;
   19 }
   20
   21 /**
   22  * @brief Загрузка конфигурации.
   23  */
   24 void AppConfig_Init(void) {
   25     // Читаем данные напрямую из Flash-памяти
   26     AppConfig_t* flash_cfg = (AppConfig_t*)APP_CONFIG_FLASH_ADDR;
   27
   28     // Проверяем Magic Key и контрольную сумму
   29     if (flash_cfg->magic == APP_CONFIG_MAGIC && 
   30         flash_cfg->checksum == CalculateChecksum(flash_cfg)) 
   31     {
   32         // Данные во Flash корректны, копируем их в RAM
   33         memcpy(&g_app_config, flash_cfg, sizeof(AppConfig_t));
   34     } 
   35     else 
   36     {
   37         // Flash пуст или данные повреждены: Устанавливаем "Заводские настройки"
   38         memset(&g_app_config, 0, sizeof(AppConfig_t));
   39         g_app_config.magic = APP_CONFIG_MAGIC;
   40         g_app_config.performer_id = 0x40; // ID по умолчанию
   41         
   42         // Заполняем таблицу маппинга 0xFF (пусто)
   43         for (int i = 0; i < DS18B20_MAX_SENSORS; i++) {
   44             memset(g_app_config.sensors[i].rom_code, 0xFF, 8);
   45         }
   46         
   47         // Считаем контрольную сумму для новой структуры
   48         g_app_config.checksum = CalculateChecksum(&g_app_config);
   49         
   50         // Опционально: можно сразу сохранить заводские настройки во Flash
   51         // AppConfig_Save(); 
   52     }
   53 }
   54
   55 /**
   56  * @brief Сохранение конфигурации во Flash.
   57  */
   58 bool AppConfig_Save(void) {
   59     HAL_StatusTypeDef status;
   60     uint32_t PageError = 0;
   61     FLASH_EraseInitTypeDef EraseInitStruct;
   62
   63     // Обновляем контрольную сумму перед сохранением
   64     g_app_config.checksum = CalculateChecksum(&g_app_config);
   65
   66     // 1. Разблокировка Flash
   67     HAL_FLASH_Unlock();
   68
   69     // 2. Очистка страницы (STM32 требует очистки перед записью)
   70     EraseInitStruct.TypeErase   = FLASH_TYPEERASE_PAGES;
   71     EraseInitStruct.PageAddress = APP_CONFIG_FLASH_ADDR;
   72     EraseInitStruct.NbPages     = 1;
   73
   74     status = HAL_FLASHEx_Erase(&EraseInitStruct, &PageError);
   75     if (status != HAL_OK) {
   76         HAL_FLASH_Lock();
   77         return false;
   78     }
   79
   80     // 3. Запись структуры по 4 байта (32-битные слова)
   81     uint32_t* pData = (uint32_t*)&g_app_config;
   82     uint32_t addr = APP_CONFIG_FLASH_ADDR;
   83     
   84     for (uint32_t i = 0; i < sizeof(AppConfig_t); i += 4) {
   85         status = HAL_FLASH_Program(FLASH_TYPEPROGRAM_WORD, addr, *pData);
   86         if (status != HAL_OK) break;
   87         addr += 4;
   88         pData++;
   89     }
   90
   91     // 4. Блокировка Flash
   92     HAL_FLASH_Lock();
   93
   94     return (status == HAL_OK);
   95 }

  Обоснование:
   1. Надежность: Проверка checksum и magic исключает использование случайного мусора из памяти при первом запуске.
   2. Заводские настройки: Если Flash пуст, плата автоматически инициализируется с ID 0x40 и пустыми датчиками.
   3. Атомарность: STM32 требует полной очистки страницы (1 КБ) перед записью, что мы и делаем через HAL_FLASHEx_Erase.


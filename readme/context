   14 #include "task_dispatcher.h"
   15 #include "main.h"
   16 #include "cmsis_os.h"
   17 #include "app_queues.h"
   18 #include "app_config.h"
   19 #include "app_globals.h"
   20 #include "can_protocol.h"
   21 #include <string.h>
   22
   23 void app_start_task_dispatcher(void *argument) {
   24     ParsedCanCommand_t parsed; // Буфер для принятой команды
   25
   26     for (;;) {
   27         // Ожидаем команду из parser_queue (от Task_CAN_Handler)
   28         if (osMessageQueueGet(parser_queueHandle, &parsed, NULL, osWaitForever) != osOK) {
   29             continue;
   30         }
   31
   32         // --- 1. Немедленное подтверждение (ACK) ---
   33         CAN_SendAck(parsed.cmd_code);
   34
   35         // --- 2. Диспетчеризация команды ---
   36         switch (parsed.cmd_code) {
   37             case CAN_CMD_SENSOR_GET_TEMP: {
   38                 uint8_t sensor_index = parsed.sensor_id;
   39                 
   40                 if (sensor_index < DS18B20_MAX_SENSORS) {
   41                     float raw_temp = g_latest_temperatures[sensor_index];
   42                     
   43                     // Конвертация float -> int16_t (0.1°C resolution)
   44                     // Пример: 25.46 -> 255
   45                     int16_t tx_temp = (int16_t)(raw_temp * 10.0f);
   46                     
   47                     // --- 3. Отправка данных (DATA) ---
   48                     uint8_t tx_data[2];
   49                     tx_data[0] = (uint8_t)(tx_temp & 0xFF);
   50                     tx_data[1] = (uint8_t)((tx_temp >> 8) & 0xFF);
   51                     
   52                     CAN_SendData(parsed.cmd_code, tx_data, 2);
   53                     
   54                     // --- 4. Завершение транзакции (DONE) ---
   55                     CAN_SendDone(parsed.cmd_code, sensor_index);
   56                 } else {
   57                     // Ошибка: неверный индекс датчика
   58                     CAN_SendNack(parsed.cmd_code, CAN_ERR_INVALID_SENSOR_ID);
   59                 }
   60                 break;
   61             }
   62
   63             case CAN_CMD_SENSOR_GET_ALL_TEMPS: {
   64                 // TODO: Реализовать циклическую отправку всех датчиков
   65                 CAN_SendDone(parsed.cmd_code, 0xFF);
   66                 break;
   67             }
   68
   69             default:
   70                 // Неизвестная команда
   71                 CAN_SendNack(parsed.cmd_code, CAN_ERR_UNKNOWN_CMD);
   72                 break;
   73         }
   74     }
   75 }


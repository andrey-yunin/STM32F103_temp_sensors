   16 // --- Микросекундная задержка (TIM3) ---
   17 void delay_us(uint32_t us)
   18 {
   19     __HAL_TIM_SET_COUNTER(&htim3, 0);
   20     while(__HAL_TIM_GET_COUNTER(&htim3) < us);

   102 bool OneWire_Search(uint8_t *newAddr) {
   103     uint8_t id_bit_number = 1, last_zero = 0, rom_byte_number = 0, rom_byte_mask = 1;
   104     bool id_bit, cmp_id_bit, search_direction, search_result = false;
   105
   106     if (!LastDeviceFlag) {
   107         if (!OneWire_Reset()) {
   108             LastDiscrepancy = 0; LastDeviceFlag = false; return false;
   109         }
   110         OneWire_WriteByte(DS18B20_CMD_SEARCHROM);
   111         while (rom_byte_number < 8) {
   112             id_bit = OneWire_ReadBit();
   113             cmp_id_bit = OneWire_ReadBit();
   114             if (id_bit && cmp_id_bit) break; // Error: No response
   115             else {
   116                 if (id_bit != cmp_id_bit) search_direction = id_bit;
   117                 else {
   118                     if (id_bit_number < LastDiscrepancy)
   119                         search_direction = ((ROM_NO[rom_byte_number] & rom_byte_mask) > 0);
   120                     else
   121                         search_direction = (id_bit_number == LastDiscrepancy);
   122                     if (search_direction == 0) last_zero = id_bit_number;
   123                 }
   124                 if (search_direction == 1) ROM_NO[rom_byte_number] |= rom_byte_mask;
   125                 else ROM_NO[rom_byte_number] &= ~rom_byte_mask;
   126                 OneWire_WriteBit(search_direction);
   127                 id_bit_number++; rom_byte_mask <<= 1;
   128                 if (rom_byte_mask == 0) { rom_byte_number++; rom_byte_mask = 1; }
   129             }
   130         }
   131         if (!(id_bit_number < 65)) {
   132             LastDiscrepancy = last_zero;
   133             if (LastDiscrepancy == 0) LastDeviceFlag = true;
   134             search_result = true;
   135         }
   136     }
   137     if (!search_result || !ROM_NO[0]) {
   138         LastDiscrepancy = 0; LastDeviceFlag = false; search_result = false;
   139     } else {
   140         for (int i = 0; i < 8; i++) newAddr[i] = ROM_NO[i];
   141     }
   142     return search_result;
   143 }

    9 #ifndef CAN_PROTOCOL_H_
   10 #define CAN_PROTOCOL_H_
   11
   12 #include <stdint.h>
   13 #include <stdbool.h>
   14
   15 // ============================================================
   16 // Приоритеты (биты 28-26 CAN ID)
   17 // ============================================================
   18 #define CAN_PRIORITY_HIGH       0   // Команды от дирижера
   19 #define CAN_PRIORITY_NORMAL     1   // Ответы от исполнителей
   20
   21 // ============================================================
   22 // Типы сообщений (биты 25-24 CAN ID)
   23 // ============================================================
   24 #define CAN_MSG_TYPE_COMMAND        0   // Команда (Conductor -> Executor)
   25 #define CAN_MSG_TYPE_ACK            1   // Подтверждение (Executor -> Conductor)
   26 #define CAN_MSG_TYPE_NACK           2   // Ошибка (Executor -> Conductor)
   27 #define CAN_MSG_TYPE_DATA_DONE_LOG  3   // DATA/DONE/LOG (Executor -> Conductor)
   28
   29 // ============================================================
   30 // Подтипы для MSG_TYPE_DATA_DONE_LOG (первый байт payload)
   31 // ============================================================
   32 #define CAN_SUB_TYPE_DONE       0x01
   33 #define CAN_SUB_TYPE_DATA       0x02
   34 #define CAN_SUB_TYPE_LOG        0x03
   35
   36 // ============================================================
   37 // Адреса узлов (биты 23-16 dst, 15-8 src)
   38 // ============================================================
   39 #define CAN_ADDR_BROADCAST      0x00
   40 #define CAN_ADDR_HOST           0x01
   41 #define CAN_ADDR_CONDUCTOR      0x10
   42 #define CAN_ADDR_THERMO_BOARD   0x40  // Наш адрес (Плата термодатчиков)
   43
   44 // ============================================================
   45 // Коды команд сенсоров (байты 0-1 payload, Little-Endian)
   46 // ============================================================
   47 #define CAN_CMD_SENSOR_GET_TEMP      0x9011 // Запрос конкретного датчика
   48 #define CAN_CMD_SENSOR_GET_ALL_TEMPS  0x9010 // Запрос всех датчиков
   49
   50 // ============================================================
   51 // Макрос построения 29-bit Extended CAN ID
   52 // ============================================================
   53 #define CAN_BUILD_ID(priority, msg_type, dst_addr, src_addr) \
   54     ((uint32_t)(((priority) & 0x07) << 26) | \
   55                 (((msg_type) & 0x03) << 24) | \
   56                 (((dst_addr) & 0xFF) << 16) | \
   57                 (((src_addr) & 0xFF) << 8))
   58
   59 // ============================================================
   60 // Макросы извлечения полей из 29-bit CAN ID
   61 // ============================================================
   62 #define CAN_GET_PRIORITY(id)    ((uint8_t)(((id) >> 26) & 0x07))
   63 #define CAN_GET_MSG_TYPE(id)    ((uint8_t)(((id) >> 24) & 0x03))
   64 #define CAN_GET_DST_ADDR(id)    ((uint8_t)(((id) >> 16) & 0xFF))
   65 #define CAN_GET_SRC_ADDR(id)    ((uint8_t)(((id) >> 8)  & 0xFF))
   66
   67 // ============================================================
   68 // Коды ошибок для NACK-ответов
   69 // ============================================================
   70 #define CAN_ERR_NONE                0x0000
   71 #define CAN_ERR_UNKNOWN_CMD         0x0001
   72 #define CAN_ERR_INVALID_SENSOR_ID   0x0002
   73 #define CAN_ERR_SENSOR_FAILURE      0x0003
   74
   75 // ============================================================
   76 // Внутренние структуры для передачи в Dispatcher
   77 // ============================================================
   78
   79 typedef struct {
   80     uint16_t cmd_code;   // Код команды (Little-Endian)
   81     uint8_t  sensor_id;  // ID сенсора (параметр)
   82     uint8_t  data[5];    // Дополнительные данные (если есть)
   83     uint8_t  data_len;
   84 } ParsedCanCommand_t;
   85
   86 // ============================================================
   87 // Прототипы функций отправки ответов (будут реализованы в task_can_handler)
   88 // ============================================================
   89 void CAN_SendAck(uint16_t cmd_code);
   90 void CAN_SendNack(uint16_t cmd_code, uint16_t error_code);
   91 void CAN_SendDone(uint16_t cmd_code, uint8_t sensor_id);
   92 void CAN_SendData(uint16_t cmd_code, uint8_t *data, uint8_t len);
   93
   94 #endif /* CAN_PROTOCOL_H_ */


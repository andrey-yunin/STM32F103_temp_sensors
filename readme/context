   23 // --- Низкоуровневые функции протокола 1-Wire (Оптимизированные) ---
   24
   25 bool OneWire_Reset()
   26 {
   27     bool presence = false;
   28     ONE_WIRE_LOW();      // Тянем в LOW
   29     delay_us(480);       // Reset Pulse
   30     ONE_WIRE_HIGH();     // Отпускаем (High-Z)
   31     delay_us(70);        // Wait for Presence pulse
   32
   33     if (!ONE_WIRE_READ()) {
   34         presence = true; // Датчик притянул шину к земле (Presence)
   35     }
   36     delay_us(410);       // Recovery time
   37     return presence;
   38 }
   39
   40 void OneWire_WriteBit(bool bit)
   41 {
   42     if (bit) {
   43         // Write '1' slot
   44         ONE_WIRE_LOW();
   45         delay_us(6);
   46         ONE_WIRE_HIGH(); // Release
   47         delay_us(64);
   48     } else {
   49         // Write '0' slot
   50         ONE_WIRE_LOW();
   51         delay_us(60);
   52         ONE_WIRE_HIGH(); // Release
   53         delay_us(10);
   54     }
   55 }
   56
   57 bool OneWire_ReadBit()
   58 {
   59     bool bit = false;
   60     ONE_WIRE_LOW();
   61     delay_us(6);
   62     ONE_WIRE_HIGH(); // Release
   63     delay_us(9);     // Master sample time
   64
   65     if (ONE_WIRE_READ()) {
   66         bit = true;
   67     }
   68     delay_us(55);
   69     return bit;
   70 }
   71
   72 void OneWire_WriteByte(uint8_t byte)
   73 {
   74     for (uint8_t i = 0; i < 8; i++) {
   75         OneWire_WriteBit((byte >> i) & 0x01);
   76     }
   77 }

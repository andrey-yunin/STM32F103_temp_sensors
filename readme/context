   112                 addr += 4; pData++;
   113             }
   114         }
   115         
   116         HAL_FLASH_Lock();
   117         success = (status == HAL_OK);
   118         osMutexRelease(configMutex);
   119     }
   120     return success;
   121 }

  Обоснование:
   1. Thread Safety: Все функции доступа (Get/Set/Commit) используют osMutexAcquire, что исключает Race Conditions.
   2. Encapsulation: Переменная g_app_config теперь static. Никто снаружи не может изменить её, минуя мьютекс.
   3. Advanced Logic: Используется рекурсивный мьютекс с наследованием приоритетов (osMutexPrioInherit), что предотвращает инверсию приоритетов в RTOS.


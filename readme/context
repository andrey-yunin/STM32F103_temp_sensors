  Нам нужно заменить «заглушку» на реальный цикл опроса.

  Действие: ЗАМЕНИТЬ содержимое основного цикла в task_temp_monitor.c

    1 void app_start_task_temp_monitor(void *argument)
    2 {
    3     // Инициализация при старте: поиск всех датчиков
    4     uint8_t found_sensors = DS18B20_Init();
    5     float temp_val = 0.0f;
    6
    7     for(;;)
    8     {
    9         if (found_sensors > 0) 
   10         {
   11             // 1. Запускаем конвертацию на ВСЕХ датчиках одновременно (Broadcast)
   12             DS18B20_StartAll(); 
   13             
   14             // 2. Ждем завершения (750мс для 12-битной точности)
   15             osDelay(750);      
   16
   17             // 3. Читаем данные с каждого найденного датчика индивидуально
   18             for (uint8_t i = 0; i < found_sensors; i++) 
   19             {
   20                 DS18B20_ROM_t* rom = DS18B20_GetROM(i);
   21                 if (DS18B20_ReadTemperature(rom, &temp_val)) 
   22                 {
   23                     // Сохраняем в глобальный массив для Dispatcher
   24                     g_latest_temperatures[i] = temp_val;
   25                 } 
   26                 else 
   27                 {
   28                     // В случае ошибки (например, CRC) можно записать спец-значение
   29                     g_latest_temperatures[i] = -999.0f; 
   30                 }
   31             }
   32         }
   33         else 
   34         {
   35             // Если датчиков нет, пробуем инициализировать снова через время
   36             osDelay(1000);
   37             found_sensors = DS18B20_Init();
   38         }

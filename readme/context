    9 #define ONE_WIRE_LOW()      (ONE_WIRE_BUS_GPIO_Port->BRR = ONE_WIRE_BUS_Pin)
   10 #define ONE_WIRE_HIGH()     (ONE_WIRE_BUS_GPIO_Port->BSRR = ONE_WIRE_BUS_Pin)
   11 #define ONE_WIRE_READ()     ((ONE_WIRE_BUS_GPIO_Port->IDR & ONE_WIRE_BUS_Pin) != 0)

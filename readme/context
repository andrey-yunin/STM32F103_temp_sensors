   20 /**
   21  * @brief Безопасное чтение температуры из другого потока (например, из Dispatcher).
   22  */
   23 float TempMonitor_GetTemperature(uint8_t index) {
   24     float val = -999.0f;
   25     if (index < DS18B20_MAX_SENSORS && tempMutex != NULL) {
   26         if (osMutexAcquire(tempMutex, 10) == osOK) { // Ждем максимум 10мс
   27             val = s_latest_temperatures[index];
   28             osMutexRelease(tempMutex);
   29         }
   30     }
   31     return val;
   32 }

   15 // ============================================================
   16 // Константы протокола: 29-bit CAN ID (Спецификация 2_Frame_Format.md)
   17 // Синхронизировано с dispatcher_can_packer.h
   18 // ============================================================
   19
   20 // --- Приоритеты (биты 28-26) ---
   21 #define CAN_PRIORITY_HIGH       0   // Команды от дирижера
   22 #define CAN_PRIORITY_NORMAL     1   // Ответы от исполнителей
   23
   24 // --- Типы сообщений (биты 25-24) ---
   25 #define CAN_MSG_TYPE_COMMAND    0   // Команда (Conductor → Executor)
   26 #define CAN_MSG_TYPE_ACK        1   // Подтверждение (Executor → Conductor)
   27 #define CAN_MSG_TYPE_NACK       2   // Ошибка выполнения (Executor → Conductor)
   28 #define CAN_MSG_TYPE_DATA_DONE_LOG 3 // DATA/DONE/LOG (Executor → Conductor)
   29
   30 // --- Подтипы для MSG_TYPE_DATA_DONE_LOG (первый байт полезной нагрузки) ---
   31 #define CAN_SUB_TYPE_DONE       0x01
   32 #define CAN_SUB_TYPE_DATA       0x02
   33 #define CAN_SUB_TYPE_LOG        0x03
   34
   35 // ============================================================
   36 // Коды команд (Спецификация User_Commands.md, Раздел 10)
   37 // ============================================================
   38 #define CAN_CMD_SENSOR_GET_TEMP      0x9011 // Запросить конкретный датчик температуры
   39 #define CAN_CMD_SENSOR_GET_ALL_TEMPS  0x9010 // Запросить все датчики температуры
   40 #define CAN_CMD_SENSOR_GET_STATUS    0x9012 // Запросить статус модуля (резерв)
   41
   42 // ============================================================
   43 // Макросы для работы с 29-bit CAN ID
   44 // ============================================================
   45
   46 /** @brief Конструирование ID: Приоритет(3) | Тип(2) | Куда(8) | Откуда(8) | Res(8) */
   47 #define CAN_BUILD_ID(priority, msg_type, dst_addr, src_addr) \
   48     ((uint32_t)(((priority) & 0x07) << 26) | \
   49                 (((msg_type) & 0x03) << 24) | \
   50                 (((dst_addr) & 0xFF) << 16) | \
   51                 (((src_addr) & 0xFF) << 8))
   52
   53 // Макросы извлечения полей
   54 #define CAN_GET_PRIORITY(id)    ((uint8_t)(((id) >> 26) & 0x07))
   55 #define CAN_GET_MSG_TYPE(id)    ((uint8_t)(((id) >> 24) & 0x03))
   56 #define CAN_GET_DST_ADDR(id)    ((uint8_t)(((id) >> 16) & 0xFF))
   57 #define CAN_GET_SRC_ADDR(id)    ((uint8_t)(((id) >> 8)  & 0xFF))

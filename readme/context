    1 /*
    2  * task_dispatcher.c
    3  *
    4  *  Прикладной уровень (Parser/Dispatcher). 
    5  *  Реализует логику обработки команд и жизненный цикл транзакции (ACK-DATA-DONE).
    6  */
    7
    8 #include "main.h"
    9 #include "cmsis_os.h"
   10 #include "app_queues.h"
   11 #include "app_config.h"
   12 #include "app_flash.h"         // Для геттера ID исполнителя
   13 #include "task_temp_monitor.h" // Для геттера температур (Thread-Safe)
   14 #include "can_protocol.h"
   15 #include <string.h>
   16
   17 void app_start_task_dispatcher(void *argument)
   18 {
   19     ParsedCanCommand_t parsed;
   20     
   21     for (;;) {
   22         // Ожидаем команду из очереди (parser_queue), наполняемой в task_can_handler
   23         if (osMessageQueueGet(parser_queueHandle, &parsed, NULL, osWaitForever) != osOK) {
   24             continue;
   25         }
   26
   27         // --- 1. Немедленное подтверждение получения команды (ACK) ---
   28         CAN_SendAck(parsed.cmd_code);
   29
   30         // --- 2. Диспетчеризация по коду команды ---
   31         switch (parsed.cmd_code) {
   32
   33             case CAN_CMD_SENSOR_GET_TEMP: {
   34                 uint8_t idx = parsed.sensor_id;
   35                 
   36                 if (idx < DS18B20_MAX_SENSORS) {
   37                     // Читаем значение из защищенного хранилища монитора
   38                     float raw_t = TempMonitor_GetTemperature(idx);
   39                     
   40                     if (raw_t > -100.0f) { // Датчик в сети и данные валидны
   41                         // Конвертация: float -> int16_t (0.1°C precision)
   42                         int16_t tx_val = (int16_t)(raw_t * 10.0f);
   43                         uint8_t data[2];
   44                         data[0] = (uint8_t)(tx_val & 0xFF);
   45                         data[1] = (uint8_t)((tx_val >> 8) & 0xFF);
   46                         
   47                         // --- 3. Отправка полезных данных (DATA) ---
   48                         CAN_SendData(parsed.cmd_code, data, 2);
   49                         // --- 4. Завершение успешной транзакции (DONE) ---
   50                         CAN_SendDone(parsed.cmd_code, idx);
   51                     } else {
   52                         // Датчик не ответил в цикле мониторинга
   53                         CAN_SendNack(parsed.cmd_code, CAN_ERR_SENSOR_FAILURE);
   54                     }
   55                 } else {
   56                     // Запрошен индекс за пределами массива (например, 25)
   57                     CAN_SendNack(parsed.cmd_code, CAN_ERR_INVALID_SENSOR_ID);
   58                 }
   59                 break;
   60             }
   61
   62             case CAN_CMD_SENSOR_GET_ALL_TEMPS: {
   63                 // Пакетная отправка данных по всем активным датчикам
   64                 for (uint8_t i = 0; i < DS18B20_MAX_SENSORS; i++) {
   65                     float t = TempMonitor_GetTemperature(i);
   66                     if (t > -100.0f) {
   67                         int16_t tx_v = (int16_t)(t * 10.0f);
   68                         uint8_t d[3];
   69                         d[0] = i; // Префикс данных: индекс датчика
   70                         d[1] = (uint8_t)(tx_v & 0xFF);
   71                         d[2] = (uint8_t)((tx_v >> 8) & 0xFF);
   72                         CAN_SendData(parsed.cmd_code, d, 3);
   73                     }
   74                 }
   75                 CAN_SendDone(parsed.cmd_code, 0xFF); // 0xFF - маркер "Все датчики"
   76                 break;
   77             }
   78
   79             default:
   80                 // Неизвестная команда (не реализована в данной прошивке)
   81                 CAN_SendNack(parsed.cmd_code, CAN_ERR_UNKNOWN_CMD);
   82                 break;
   83         }
   84     }

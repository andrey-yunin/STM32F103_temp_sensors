   65  */
   66 typedef struct {
   67     uint16_t command_code;  // Код команды (напр. 0x9011), Little-Endian в CAN
   68     uint8_t  source_addr;   // Адрес отправителя (обычно CAN_ADDR_CONDUCTOR)
   69     uint8_t  payload[6];    // Параметры команды (после кода команды)
   70     uint8_t  payload_len;   // Длина параметров (DLC - 2)

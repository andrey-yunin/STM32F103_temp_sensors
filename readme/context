     1 // Глобальные переменные для поиска
     2 static uint8_t ROM_NO[8];
     3 static uint8_t LastDiscrepancy;
     4 static uint8_t LastFamilyDiscrepancy;
     5 static bool LastDeviceFlag;
     6
     7 /**
     8  * @brief Поиск следующего устройства на шине 1-Wire.
     9  * Базируется на алгоритме из Application Note 187 (Maxim Integrated).
    10  */
    11 bool OneWire_Search(uint8_t *newAddr)
    12 {
    13    uint8_t id_bit_number;
    14    uint8_t last_zero, rom_byte_number, search_direction;
    15    bool id_bit, cmp_id_bit;
    16    uint8_t rom_byte_mask;
    17    bool search_result = false;
    18
    19    if (!LastDeviceFlag) {
    20       if (!OneWire_Reset()) {
    21          LastDiscrepancy = 0;
    22          LastDeviceFlag = false;
    23          LastFamilyDiscrepancy = 0;
    24          return false;
    25       }
    26
    27       OneWire_WriteByte(DS18B20_CMD_SEARCHROM);
    28       id_bit_number = 1;
    29       last_zero = 0;
    30       rom_byte_number = 0;
    31       rom_byte_mask = 1;
    32
    33       while (rom_byte_number < 8) {
    34          id_bit = OneWire_ReadBit();
    35          cmp_id_bit = OneWire_ReadBit();
    36
    37          if (id_bit && cmp_id_bit) break; // Ошибка: никто не ответил
    38          else {
    39             if (id_bit != cmp_id_bit) search_direction = id_bit;
    40             else {
    41                if (id_bit_number < LastDiscrepancy)
    42                   search_direction = ((ROM_NO[rom_byte_number] & rom_byte_mask) > 0);
    43                else
    44                   search_direction = (id_bit_number == LastDiscrepancy);
    45
    46                if (search_direction == 0) {
    47                   last_zero = id_bit_number;
    48                   if (last_zero < 9) LastFamilyDiscrepancy = last_zero;
    49                }
    50             }
    51
    52             if (search_direction == 1) ROM_NO[rom_byte_number] |= rom_byte_mask;
    53             else ROM_NO[rom_byte_number] &= ~rom_byte_mask;
    54
    55             OneWire_WriteBit(search_direction);
    56             id_bit_number++;
    57             rom_byte_mask <<= 1;
    58             if (rom_byte_mask == 0) {
    59                rom_byte_number++;
    60                rom_byte_mask = 1;
    61             }
    62          }
    63       }
    64
    65       if (!(id_bit_number < 65)) {
    66          LastDiscrepancy = last_zero;
    67          if (LastDiscrepancy == 0) LastDeviceFlag = true;
    68          search_result = true;
    69       }
    70    }
    71
    72    if (!search_result || !ROM_NO[0]) {
    73       LastDiscrepancy = 0;
    74       LastDeviceFlag = false;
    75       LastFamilyDiscrepancy = 0;
    76       search_result = false;
    77    } else {
    78       for (int i = 0; i < 8; i++) newAddr[i] = ROM_NO[i];
    79    }
    80    return search_result;
    81 }
    82
    83 // --- Публичные функции ---
    84
    85 uint8_t DS18B20_Init()
    86 {
    87     ds18b20_sensor_count = 0;
    88     LastDiscrepancy = 0;
    89     LastDeviceFlag = false;
    90     LastFamilyDiscrepancy = 0;
    91
    92     // Ищем все датчики, пока не закончатся или не достигнем максимума
    93     while (OneWire_Search(ds18b20_rom_codes[ds18b20_sensor_count].rom_code)) {
    94         // Проверяем CRC найденного ROM-кода
    95         if (OneWire_CRC8(ds18b20_rom_codes[ds18b20_sensor_count].rom_code, 7) == ds18b20_rom_codes[ds18b20_sensor_count].rom_code[7]) {
    96             ds18b20_sensor_count++;
    97         }
    98         if (ds18b20_sensor_count >= DS18B20_MAX_SENSORS) break;
    99     }
   100     return ds18b20_sensor_count;
   101 }


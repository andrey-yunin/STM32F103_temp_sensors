   36 void app_start_task_temp_monitor(void *argument) {
   37     // 1. Инициализация мьютекса защиты данных
   38     tempMutex = osMutexNew(&tempMutex_attr);
   39
   40     // 2. Инициализация массива начальными значениями "Ошибки"
   41     for (uint8_t i = 0; i < DS18B20_MAX_SENSORS; i++) {
   42         s_latest_temperatures[i] = -999.0f;
   43     }
   44
   45     // Буферы для работы в цикле
   46     DS18B20_ROM_t target_rom;
   47     float current_temp = 0.0f;
   48
   49     for(;;) {
   50         // 3. ШИРОКОВЕЩАТЕЛЬНЫЙ ЗАПУСК: Все датчики на шине начинают мерить температуру.
   51         DS18B20_StartAll(); 
   52         
   53         // 4. ОЖИДАНИЕ: Даем датчикам время на замер (750мс).
   54         osDelay(800); 
   55
   56         // 5. ОПРОС ПО ТАБЛИЦЕ МАППИНГА (из Flash)
   57         for (uint8_t i = 0; i < DS18B20_MAX_SENSORS; i++) {
   58             // Читаем ROM ID для канала 'i' из защищенной конфигурации
   59             AppConfig_GetSensorROM(i, &target_rom);
   60
   61             // Проверяем, привязан ли датчик (первый байт DS18B20 всегда 0x28)
   62             if (target_rom.rom_code[0] == 0x28) {
   63                 // Адресное чтение конкретного датчика
   64                 if (DS18B20_ReadTemperature(&target_rom, &current_temp)) {
   65                     // Успех: сохраняем результат под защитой мьютекса
   66                     if (osMutexAcquire(tempMutex, osWaitForever) == osOK) {
   67                         s_latest_temperatures[i] = current_temp;
   68                         osMutexRelease(tempMutex);
   69                     }
   70                 } else {
   71                     // Ошибка чтения (датчик пропал или помеха)
   72                     s_latest_temperatures[i] = -999.0f;
   73                 }
   74             } else {
   75                 // Канал не настроен (пусто во Flash)
   76                 s_latest_temperatures[i] = -999.0f;
   77             }
   78         }
   79         
   80         // Пауза между полными циклами опроса всей системы
   81         osDelay(2000); 
   82     }
   83 }

  Почему это решение «Advanced»?
   1. Thread Safety (Мьютексы): Теперь данные защищены от одновременного доступа. Если task_dispatcher захочет прочитать температуру Реагента №2, он вызовет
      TempMonitor_GetTemperature(1), которая корректно дождется завершения записи данных монитором.
   2. Mapping-First: Мы больше не зависим от порядка обнаружения датчиков. Мы читаем только те ID, которые были «обучены» инженером.
   3. Encapsulation: Мы убрали массив из глобальной области. Это предотвращает случайные ошибки «затирания» данных из других модулей.


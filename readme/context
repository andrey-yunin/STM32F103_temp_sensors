    3 // Callback-функция, вызываемая, когда в FIFO0 CAN1 появляется новое сообщение
    4 void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
    5 {
    6     CanRxFrame_t rx_frame;
    7     // Извлекаем сообщение из аппаратного буфера CAN FIFO0
    8     if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rx_frame.header, rx_frame.data) == HAL_OK)
    9         {
   10         // Помещаем весь фрейм в очередь can_rx_queue для обработки
   11         osMessageQueuePut(can_rx_queueHandle, &rx_frame, 0, 0); // priority 0, timeout 0 (немедленно)
   12         osThreadFlagsSet(task_can_handleHandle, FLAG_CAN_RX); // Уведомляем CAN Handler о новом фрейме
   13         }
   14 }
   15
   16 /* USER CODE END 1 */


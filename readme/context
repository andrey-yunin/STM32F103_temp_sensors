   79 uint8_t OneWire_ReadByte()
   80 {
   81     uint8_t byte = 0;
   82     for (uint8_t i = 0; i < 8; i++) {
   83         if (OneWire_ReadBit()) {
   84             byte |= (0x01 << i);
   85         }
   86     }
   87     return byte;
   88 }


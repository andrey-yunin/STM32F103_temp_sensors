    1 /*
    2  * task_command_parser.c (Dispatcher)
    3  *
    4  *  Created on: Dec 8, 2025
    5  *      Author: andrey
    6  *
    7  *    Прикладной уровень. Отвечает за:
    8  *  - Приём ParsedCanCommand_t из parser_queue (от CAN Handler)
    9  *  - Валидацию параметров (sensor_id)
   10  *  - Формирование ответов по жизненному циклу (ACK -> DATA -> DONE)
   11  *  - Использование потокобезопасных аксессоров к данным (Thread-Safe API)
   12  */
   13
   14 #include "main.h"
   15 #include "cmsis_os.h"
   16 #include "app_queues.h"
   17 #include "app_config.h"
   18 #include "app_flash.h"      // Для доступа к конфигурации (ID платы)
   19 #include "task_temp_monitor.h" // Для получения температур через TempMonitor_GetTemperature
   20 #include "can_protocol.h"
   21 #include <string.h>
   22
   23 void app_start_task_dispatcher(void *argument)
   24 {
   25     ParsedCanCommand_t parsed;
   26     for (;;) {
   27         // Ожидаем команду из parser_queue (от Task_CAN_Handler)
   28         if (osMessageQueueGet(parser_queueHandle, &parsed, NULL, osWaitForever) != osOK) {
   29             continue;
   30         }
   31
   32         // --- 1. Немедленное подтверждение (ACK) ---
   33         CAN_SendAck(parsed.cmd_code);
   34
   35         // --- 2. Диспетчеризация команды ---
   36         switch (parsed.cmd_code) {
   37
   38             case CAN_CMD_SENSOR_GET_TEMP: {
   39                 uint8_t sensor_index = parsed.sensor_id;
   40                 if (sensor_index < DS18B20_MAX_SENSORS) {
   41                     
   42                     // БЕЗОПАСНОЕ ПОЛУЧЕНИЕ ДАННЫХ через аксессор монитора
   43                     float raw_temp = TempMonitor_GetTemperature(sensor_index);
   44                     
   45                     // Если датчик вернул -999.0, значит он офлайн или ошибка чтения
   46                     if (raw_temp < -100.0f) {
   47                         CAN_SendNack(parsed.cmd_code, CAN_ERR_SENSOR_FAILURE);
   48                         break;
   49                     }
   50
   51                     // Конвертация float -> int16_t (0.1°C resolution)
   52                     // Пример: 25.46 -> 255
   53                     int16_t tx_temp = (int16_t)(raw_temp * 10.0f);
   54
   55                     // --- 3. Отправка данных (DATA) ---
   56                     uint8_t tx_data[2];
   57                     tx_data[0] = (uint8_t)(tx_temp & 0xFF);
   58                     tx_data[1] = (uint8_t)((tx_temp >> 8) & 0xFF);
   59                     CAN_SendData(parsed.cmd_code, tx_data, 2);
   60
   61                     // --- 4. Завершение транзакции (DONE) ---
   62                     CAN_SendDone(parsed.cmd_code, sensor_index);
   63                 }
   64                 else {

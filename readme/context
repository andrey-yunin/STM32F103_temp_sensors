    4 #include <stdint.h>
    5
    6 /**
    7  * @brief Типы сообщений в протоколе DDS-240
    8  */
    9 typedef enum {
   10     MSG_TYPE_COMMAND = 0x0, // Команда от Дирижера к Исполнителю
   11     MSG_TYPE_ACK     = 0x1, // Подтверждение получения команды
   12     MSG_TYPE_NACK    = 0x2, // Ошибка выполнения/парсинга команды
   13     MSG_TYPE_DATA    = 0x3  // Данные, завершение (DONE) или логи
   14 } MessageType_t;
   15
   16 /**
   17  * @brief Подтипы для сообщений типа DATA (MSG_TYPE_DATA)
   18  */
   19 typedef enum {
   20     SUB_TYPE_DONE    = 0x01, // Команда успешно завершена
   21     SUB_TYPE_DATA    = 0x02, // Передача данных
   22     SUB_TYPE_LOG     = 0x03  // Лог-сообщение
   23 } SubType_t;
   24
   25 /**
   26  * @brief Коды команд (Low-Level Command Set)
   27  * Диапазон 0x03xx зарезервирован для сенсоров.
   28  */
   29 typedef enum {
   30     CMD_GET_TEMPERATURE = 0x0301, // Запросить температуру с датчика
   31     CMD_GET_STATUS      = 0x0302  // Запросить статус модуля
   32 } CommandID_t;
   33
   34 /**
   35  * @brief Структура 29-битного расширенного ID (Extended ID)
   36  * Используется битовое поле для удобного доступа к сегментам.
   37  */
   38 typedef union {
   39     struct {
   40         uint32_t reserved    : 8;  // Биты 0-7: Зарезервировано (0)
   41         uint32_t source_addr : 8;  // Биты 8-15: Адрес источника
   42         uint32_t dest_addr   : 8;  // Биты 16-23: Адрес назначения
   43         uint32_t msg_type    : 2;  // Биты 24-25: Тип сообщения (MessageType_t)
   44         uint32_t priority    : 3;  // Биты 26-28: Приоритет (0-7, 0 - высший)
   45         uint32_t unused      : 3;  // Не используется (для 32-битного выравнивания)
   46     } fields;
   47     uint32_t full_id;
   48 } CAN_ID_Union;
   49
   50 /**
   51  * @brief Структура внутренней команды для диспетчера
   52  */
   53 typedef struct {
   54     uint16_t      command_id;   // Код команды (CommandID_t)
   55     uint8_t       source_addr;  // Адрес отправителя
   56     MessageType_t msg_type;     // Тип сообщения
   57     uint8_t       payload[6];   // Полезная нагрузка (после кода команды)
   58     uint8_t       payload_len;
   59 } CAN_Command_t;
   60
   61 #endif /* COMMAND_PROTOCOL_H_ */


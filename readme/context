    12 // Версия прошивки для ответа на системные запросы
    13 #define SW_REV_MAJOR    1
    14 #define SW_REV_MINOR    0
    15
    16 void app_start_task_dispatcher(void *argument)
    17 {
    18     ParsedCanCommand_t parsed;
    19     DS18B20_ROM_t temp_rom;
    20     
    21     for (;;) {
    22         // Ожидаем команду из очереди от CAN Handler
    23         if (osMessageQueueGet(parser_queueHandle, &parsed, NULL, osWaitForever) != osOK) {
    24             continue;
    25         }
    26
    27         // 1. Подтверждаем получение команды (ACK)
    28         CAN_SendAck(parsed.cmd_code);
    29
    30         // 2. Обработка команды
    31         switch (parsed.cmd_code) {
    32
    33             /* --- РАБОЧИЙ СЛОЙ (0x90xx) --- */
    34
    35             case CAN_CMD_SENSOR_GET_TEMP: {
    36                 if (parsed.sensor_id < DS18B20_MAX_SENSORS) {
    37                     // Используем безопасный API из монитора
    38                     float raw_temp = TempMonitor_GetTemperature(parsed.sensor_id);
    39                     
    40                     // Конвертация в INT16 (0.1°C resolution)
    41                     int16_t tx_temp = (int16_t)(raw_temp * 10.0f);
    42                     uint8_t tx_data[2];
    43                     tx_data[0] = (uint8_t)(tx_temp & 0xFF);
    44                     tx_data[1] = (uint8_t)((tx_temp >> 8) & 0xFF);
    45                     
    46                     CAN_SendData(parsed.cmd_code, tx_data, 2);
    47                     CAN_SendDone(parsed.cmd_code, parsed.sensor_id);
    48                 } else {
    49                     CAN_SendNack(parsed.cmd_code, CAN_ERR_INVALID_SENSOR_ID);
    50                 }
    51                 break;
    52             }
    53
    54             /* --- СЕРВИСНЫЙ СЛОЙ: УНИВЕРСАЛЬНЫЕ (0xF0xx) --- */
    55
    56             case CMD_SRV_GET_DEVICE_INFO: {
    57                 uint8_t info[5];
    58                 info[0] = 0x01;          // HW Rev
    59                 info[1] = SW_REV_MAJOR;  // SW Major
    60                 info[2] = SW_REV_MINOR;  // SW Minor
    61                 // Упрощенно передаем 2 байта uptime (минуты)
    62                 uint16_t uptime = (uint16_t)(osKernelGetTickCount() / 60000);
    63                 info[3] = (uint8_t)(uptime & 0xFF);
    64                 info[4] = (uint8_t)(uptime >> 8);
    65                 
    66                 CAN_SendData(parsed.cmd_code, info, 5);
    67                 CAN_SendDone(parsed.cmd_code, 0);
    68                 break;
    69             }
    70
    71             case CMD_SRV_FLASH_COMMIT: {
    72                 if (AppConfig_Commit()) {
    73                     CAN_SendDone(parsed.cmd_code, 0);
    74                 } else {
    75                     CAN_SendNack(parsed.cmd_code, 0x00FF); // Flash Error
    76                 }
    77                 break;
    78             }
    79
    80             case CMD_SRV_REBOOT: {
    81                 // Код защиты magic передается в первых 2 байтах данных
    82                 uint16_t magic = (uint16_t)(parsed.data[0] | (parsed.data[1] << 8));
    83                 if (magic == SRV_MAGIC_REBOOT) {
    84                     CAN_SendDone(parsed.cmd_code, 0);
    85                     osDelay(100);
    86                     HAL_NVIC_SystemReset();
    87                 } else {
    88                     CAN_SendNack(parsed.cmd_code, 0x0001); // Wrong Magic
    89                 }
    90                 break;
    91             }
    92
    93             /* --- СЕРВИСНЫЙ СЛОЙ: ТЕРМО (0xF1xx) --- */
    94
    95             case CMD_SRV_SCAN_1WIRE: {
    96                 // Принудительный запуск поиска всех физических ID на шине
    97                 uint8_t count = DS18B20_Init();
    98                 CAN_SendData(parsed.cmd_code, &count, 1);
    99                 CAN_SendDone(parsed.cmd_code, count);
   100                 break;
   101             }
   102
   103             case CMD_SRV_GET_PHYS_ID: {
   104                 // Запрос ROM ID по индексу из списка обнаружения
   105                 DS18B20_ROM_t* rom = DS18B20_GetROM(parsed.sensor_id);
   106                 if (rom != NULL) {
   107                     uint8_t payload[9];
   108                     payload[0] = parsed.sensor_id;
   109                     memcpy(&payload[1], rom->rom_code, 8);
   110                     CAN_SendData(parsed.cmd_code, payload, 9); // Передача 9 байт через CAN_SendData (транспорт порежет на фреймы)
   111                     CAN_SendDone(parsed.cmd_code, parsed.sensor_id);
   112                 } else {
   113                     CAN_SendNack(parsed.cmd_code, CAN_ERR_INVALID_SENSOR_ID);
   114                 }
   115                 break;
   116             }
   117
   118             case CMD_SRV_SET_CHANNEL_MAP: {
   119                 // Привязка ID к логическому каналу (в RAM)
   120                 // Ожидаем в данных: [logical_id (1 byte)] + [ROM_ID (8 bytes)]
   121                 uint8_t log_id = parsed.data[0];
   122                 if (log_id < DS18B20_MAX_SENSORS) {
   123                     memcpy(temp_rom.rom_code, &parsed.data[1], 8);
   124                     AppConfig_SetSensorROM(log_id, &temp_rom);
   125                     CAN_SendDone(parsed.cmd_code, log_id);
   126                 } else {
   127                     CAN_SendNack(parsed.cmd_code, CAN_ERR_INVALID_SENSOR_ID);
   128                 }
   129                 break;
   130             }
   131
   132             default:
   133                 CAN_SendNack(parsed.cmd_code, CAN_ERR_UNKNOWN_CMD);
   134                 break;
   135         }
   136     }

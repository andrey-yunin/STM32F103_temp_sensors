    93 void app_start_task_can_handler(void *argument) {
    94     CanRxFrame_t rx_frame;
    95     CanTxFrame_t tx_frame;
    96     uint32_t txMailbox;
    97
    98     // --- Настройка CAN-фильтра (bxCAN Hardware Filter) ---
    99     // Фильтруем по DstAddr = CAN_ADDR_THERMO_BOARD (0x40)
   100     CAN_FilterTypeDef sFilterConfig;
   101     uint32_t filter_id   = ((uint32_t)CAN_ADDR_THERMO_BOARD << 16) << 3 | CAN_ID_EXT;
   102     uint32_t filter_mask = ((uint32_t)0xFF << 16) << 3 | CAN_ID_EXT;
   103
   104     sFilterConfig.FilterBank = 0;
   105     sFilterConfig.FilterMode = CAN_FILTERMODE_IDMASK;
   106     sFilterConfig.FilterScale = CAN_FILTERSCALE_32BIT;
   107     sFilterConfig.FilterIdHigh = (uint16_t)(filter_id >> 16);
   108     sFilterConfig.FilterIdLow = (uint16_t)(filter_id & 0xFFFF);
   109     sFilterConfig.FilterMaskIdHigh = (uint16_t)(filter_mask >> 16);
   110     sFilterConfig.FilterMaskIdLow = (uint16_t)(filter_mask & 0xFFFF);
   111     sFilterConfig.FilterFIFOAssignment = CAN_RX_FIFO0;
   112     sFilterConfig.FilterActivation = ENABLE;
   113     sFilterConfig.SlaveStartFilterBank = 14;
   114
   115     if (HAL_CAN_ConfigFilter(&hcan, &sFilterConfig) != HAL_OK) Error_Handler();
   116     if (HAL_CAN_Start(&hcan) != HAL_OK) Error_Handler();
   117     if (HAL_CAN_ActivateNotification(&hcan, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK) Error_Handler();
   118
   119     for (;;) {
   120         // Ожидаем прерывание (RX) или запрос на отправку (TX)
   121         uint32_t flags = osThreadFlagsWait(FLAG_CAN_RX | FLAG_CAN_TX, osFlagsWaitAny, osWaitForever);
   122
   123         // --- Обработка приема (RX) ---
   124         if (flags & FLAG_CAN_RX) {
   125             while (osMessageQueueGet(can_rx_queueHandle, &rx_frame, NULL, 0) == osOK) {
   126                 if (rx_frame.header.IDE != CAN_ID_EXT) continue;
   127
   128                 uint32_t can_id = rx_frame.header.ExtId;
   129                 if (CAN_GET_MSG_TYPE(can_id) != CAN_MSG_TYPE_COMMAND) continue;
   130                 if (rx_frame.header.DLC < 3) continue;
   131
   132                 ParsedCanCommand_t parsed;
   133                 parsed.cmd_code = (uint16_t)(rx_frame.data[0] | ((uint16_t)rx_frame.data[1] << 8));
   134                 parsed.sensor_id = rx_frame.data[2];
   135                 parsed.data_len = (rx_frame.header.DLC > 3) ? (rx_frame.header.DLC - 3) : 0;
   136                 
   137                 for (uint8_t i = 0; i < parsed.data_len && i < 5; i++) {
   138                     parsed.data[i] = rx_frame.data[3 + i];
   139                 }
   140
   141                 osMessageQueuePut(parser_queueHandle, &parsed, 0, 0);
   142             }
   143         }
   144
   145         // --- Обработка передачи (TX) ---
   146         if (flags & FLAG_CAN_TX) {
   147             while (osMessageQueueGet(can_tx_queueHandle, &tx_frame, NULL, 0) == osOK) {
   148                 HAL_CAN_AddTxMessage(&hcan, &tx_frame.header, tx_frame.data, &txMailbox);
   149             }
   150         }
   151     }
   152 }


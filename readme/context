    6 /**
    7  * @brief Задача мониторинга температуры.
    8  * Реализует промышленный цикл: Broadcast Start -> RTOS Wait -> Match ROM Read.
    9  */
   10 void app_start_task_temp_monitor(void *argument)
   11 {
   12     // 1. Инициализация при старте: Поиск всех датчиков на шине (Search ROM)
   13     uint8_t found_sensors = DS18B20_Init();
   14     float temp_val = 0.0f;
   15
   16     // Инициализируем массив температур значениями "Ошибка" (-999.0), 
   17     // пока не получены первые реальные данные.
   18     for (uint8_t i = 0; i < DS18B20_MAX_SENSORS; i++) {
   19         g_latest_temperatures[i] = -999.0f;
   20     }
   21
   22     for(;;)
   23     {
   24         if (found_sensors > 0) 
   25         {
   26             // 2. ЗАПУСК: Даем команду ВСЕМ датчикам начать измерение одновременно.
   27             // Это экономит 750мс * (N-1) времени по сравнению с поочередным запуском.
   28             DS18B20_StartAll(); 
   29             
   30             // 3. ОЖИДАНИЕ: Даем датчикам время на 12-битную конвертацию (макс 750мс).
   31             // Используем osDelay, чтобы не блокировать процессор для задач CAN и Dispatcher.
   32             osDelay(800); 
   33
   34             // 4. ЧТЕНИЕ: Обращаемся к каждому найденному датчику по его уникальному ID.
   35             for (uint8_t i = 0; i < found_sensors; i++) 
   36             {
   37                 DS18B20_ROM_t* rom = DS18B20_GetROM(i);
   38                 
   39                 // Адресное чтение (Match ROM) с проверкой CRC внутри драйвера
   40                 if (DS18B20_ReadTemperature(rom, &temp_val)) 
   41                 {
   42                     // Успех: сохраняем в глобальный массив для передачи по CAN
   43                     g_latest_temperatures[i] = temp_val;
   44                 } 
   45                 else 
   46                 {
   47                     // Ошибка (например, помеха на линии): помечаем канал как невалидный
   48                     g_latest_temperatures[i] = -999.0f; 
   49                 }
   50             }
   51         }
   52         else 
   53         {
   54             // Если датчики не найдены, пытаемся переинициализировать шину раз в 5 секунд
   55             osDelay(5000);
   56             found_sensors = DS18B20_Init();
   57         }
   58         
   59         // Пауза между полными циклами опроса всей системы (например, 2 секунды)
   60         osDelay(2000); 
   61     }
   62 }

  Обоснование решения (Advanced Level):
   1. Эффективность (Broadcast): Мы не ждем 750 мс для каждого датчика отдельно. Все 8 датчиков работают параллельно. Общее время цикла для 8 датчиков
      составит ~1.5 сек (вместо ~7 сек при поочередном ожидании).
   2. RTOS-friendly: Использование osDelay(800) вместо пустых циклов ожидания позволяет системе мгновенно отвечать на CAN-запросы от Дирижера, пока датчики
      заняты измерением.
   3. Безопасность данных: Значение -999.0f — это стандарт де-факто для обозначения ошибки сенсора. Дирижер, увидев такое число, поймет, что датчик неисправен
      или на линии помеха.
   4. Авто-восстановление: Если вы подключите датчик «на горячую» (после старта системы), через 5 секунд задача его увидит (ветка else).


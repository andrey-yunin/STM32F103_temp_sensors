    23 static uint16_t CalculateChecksum(AppConfig_t* cfg) {
    24     uint16_t checksum = 0;
    25     uint8_t* p = (uint8_t*)cfg;
    26     for (uint32_t i = 0; i < sizeof(AppConfig_t) - sizeof(uint16_t); i++) {

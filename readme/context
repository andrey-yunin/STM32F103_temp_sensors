    57 void CAN_SendDone(uint16_t cmd_code, uint8_t sensor_id) {
    58     CanTxFrame_t tx;
    59     tx.header.ExtId = CAN_BUILD_ID(CAN_PRIORITY_NORMAL, CAN_MSG_TYPE_DATA_DONE_LOG, CAN_ADDR_CONDUCTOR, CAN_ADDR_THERMO_BOARD);
    60     tx.header.IDE = CAN_ID_EXT;
    61     tx.header.RTR = CAN_RTR_DATA;
    62     tx.header.DLC = 4;
    63     tx.data[0] = CAN_SUB_TYPE_DONE;
    64     tx.data[1] = (uint8_t)(cmd_code & 0xFF);
    65     tx.data[2] = (uint8_t)((cmd_code >> 8) & 0xFF);
    66     tx.data[3] = sensor_id;
    67
    68     osMessageQueuePut(can_tx_queueHandle, &tx, 0, 0);
    69     osThreadFlagsSet(task_can_handleHandle, FLAG_CAN_TX);
    70 }
    71
    72 void CAN_SendData(uint16_t cmd_code, uint8_t *data, uint8_t len) {
    73     CanTxFrame_t tx;
    74     tx.header.ExtId = CAN_BUILD_ID(CAN_PRIORITY_NORMAL, CAN_MSG_TYPE_DATA_DONE_LOG, CAN_ADDR_CONDUCTOR, CAN_ADDR_THERMO_BOARD);
    75     tx.header.IDE = CAN_ID_EXT;
    76     tx.header.RTR = CAN_RTR_DATA;
    77     tx.header.DLC = (len > 6) ? 8 : (len + 2);
    78     tx.data[0] = CAN_SUB_TYPE_DATA;
    79     tx.data[1] = 0x80; // Sequence Info: EOT=1, Seq=0 (для одиночных пакетов)
    80     
    81     for(uint8_t i = 0; i < len && i < 6; i++) {
    82         tx.data[2 + i] = data[i];
    83     }
    84
    85     osMessageQueuePut(can_tx_queueHandle, &tx, 0, 0);
    86     osThreadFlagsSet(task_can_handleHandle, FLAG_CAN_TX);
    87 }
